# Production Environment Configuration
# Copy this to .env and fill in your production values

# ============================================
# CRITICAL: Generate New Secrets for Production
# ============================================
# Run: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_THIS_IN_PRODUCTION
JWT_SECRET_KEY=CHANGE_THIS_IN_PRODUCTION

# ============================================
# Flask Configuration
# ============================================
FLASK_ENV=production
FLASK_DEBUG=False

# ============================================
# Database Configuration (PostgreSQL Required)
# ============================================
# Format: postgresql://username:password@host:port/database
# Railway: Use DATABASE_URL from Railway dashboard
# Render: Use Internal Database URL from Render
# AWS RDS: postgresql://username:password@rds-endpoint:5432/dbname
# Docker: postgresql://postgres:postgres@postgres:5432/drishyamitra
DATABASE_URL=postgresql://username:password@host:5432/drishyamitra

# ============================================
# API Keys (Required)
# ============================================
# Groq API - Get from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ============================================
# Gmail API (Optional - For Email Delivery)
# ============================================
# Get from: https://console.cloud.google.com
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token

# ============================================
# File Upload Configuration
# ============================================
UPLOAD_FOLDER=data/photos
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,heic,webp
MAX_CONTENT_LENGTH=16777216

# ============================================
# CORS Configuration
# ============================================
# Set to your frontend domain in production
# Example: https://drishyamitra.com
CORS_ORIGINS=https://your-frontend-domain.com

# ============================================
# Security Settings
# ============================================
# Session cookie settings
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# JWT settings
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_COOKIE_SECURE=True
JWT_COOKIE_CSRF_PROTECT=True

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_FILE=app.log

# ============================================
# Performance Settings
# ============================================
# Number of worker processes (2-4 x CPU cores)
WORKERS=4
# Worker timeout in seconds
TIMEOUT=120

# ============================================
# Cloud Storage (Optional)
# ============================================
# Uncomment and configure if using cloud storage

# AWS S3
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_S3_BUCKET=your_bucket_name
# AWS_REGION=us-east-1

# Cloudinary
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# ============================================
# Monitoring & Error Tracking (Optional)
# ============================================
# Sentry DSN for error tracking
# SENTRY_DSN=your_sentry_dsn

# ============================================
# Email Configuration (Alternative to Gmail API)
# ============================================
# SMTP settings if not using Gmail API
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=your_email@gmail.com
# MAIL_PASSWORD=your_app_password

# ============================================
# Rate Limiting (Optional)
# ============================================
# RATELIMIT_ENABLED=True
# RATELIMIT_DEFAULT=100 per hour

# ============================================
# Notes
# ============================================
# 1. NEVER commit this file with real values to Git
# 2. Use strong, unique passwords for production
# 3. Keep API keys secure and rotate regularly
# 4. Enable HTTPS in production (required for secure cookies)
# 5. Set CORS_ORIGINS to your actual frontend domain
# 6. Use PostgreSQL, not SQLite, in production
# 7. Consider using a secrets manager (AWS Secrets Manager, etc.)
