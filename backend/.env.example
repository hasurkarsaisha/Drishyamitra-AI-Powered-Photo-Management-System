# Flask Configuration
FLASK_ENV=development
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# Database Configuration
# SQLite (Development - Default):
DATABASE_URL=sqlite:///drishyamitra.db

# PostgreSQL (Production - Railway):
# Railway automatically provides DATABASE_URL
# Just reference it: ${{Postgres.DATABASE_URL}}

# Groq API (REQUIRED for Chat Feature)
# Get from: https://console.groq.com/keys
# 1. Sign up at https://console.groq.com
# 2. Go to "API Keys" section
# 3. Click "Create API Key"
# 4. Copy and paste below
GROQ_API_KEY=

# Frontend URL (for CORS)
# Local: http://localhost:3000
# Railway: https://your-frontend.up.railway.app
FRONTEND_URL=http://localhost:3000

# Gmail API (OPTIONAL - Only needed for email delivery)
# Get from: https://console.cloud.google.com
# See detailed guide in API_KEYS_GUIDE.md
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# File Upload Configuration
UPLOAD_FOLDER=data/photos
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,heic,webp
MAX_CONTENT_LENGTH=104857600
